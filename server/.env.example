# Copy to server/.env and adjust.
# SQLite path is resolved by Prisma relative to prisma/schema.prisma, so
# ../../data/madrasa.db points at the repo-root data/ dir (per BUILD_CONTRACT §1).
DATABASE_URL="file:../../data/madrasa.db"
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
WHATSAPP_GATEWAY=walink
# Only used when WHATSAPP_GATEWAY=business-api (server sends the receipt PDF
# directly via the Meta WhatsApp Business Cloud API instead of opening a
# wa.me chat). Requires a verified WhatsApp Business Platform account.
WHATSAPP_BUSINESS_API_TOKEN=
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_API_VERSION=v21.0
# Set to a system Chrome path if Puppeteer's bundled Chromium is unavailable.
PUPPETEER_EXECUTABLE_PATH=
